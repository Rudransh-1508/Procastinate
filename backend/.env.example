# --- LLM (Groq) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional overrides (defaults are cheap/free Groq models):
# GROQ_AGENT_MODEL=llama-3.3-70b-versatile
# GROQ_FAST_MODEL=llama-3.1-8b-instant

# --- Auth (Google OAuth, required to sign in) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Random signing secret for JWTs — generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET=
# Where the frontend runs; OAuth redirects land back here with a token.
FRONTEND_URL=http://localhost:5173

# --- Optional integrations ---
# TODOIST_API_TOKEN=
# AW_BASE=http://localhost:5600/api/0

# --- Misc ---
# ENABLE_SCHEDULER=true
# DATA_DIR=./data
